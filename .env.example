# ParkLog Configuration
# Copy this file to .env (or .env.demo / .env.production) and fill in your values

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 📍 Google Apps Script Web App URL
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Demo — for showcasing to new clients
# APPS_SCRIPT_URL=https://script.google.com/macros/d/[YOUR-DEMO-SCRIPT-ID]/usercontent

# Production — client's own Google Sheet + Apps Script
# APPS_SCRIPT_URL=https://script.google.com/macros/d/[CLIENT-SCRIPT-ID]/usercontent

# Choose ONE:
APPS_SCRIPT_URL=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🌍 Environment
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
APP_ENV=development
# Options: development | demo | production
